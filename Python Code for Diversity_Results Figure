import numpy as np
import matplotlib.pyplot as plt
import os
import shutil
from skimage.metrics import structural_similarity as ssim
from skimage.metrics import peak_signal_noise_ratio as psnr
from skimage.color import rgb2lab, deltaE_ciede2000

# 1. Create output directory
output_dir = "dataset_diversity_results"
os.makedirs(output_dir, exist_ok=True)

# 2. Define your baseline and ICMT operators (Plug your math here)
def baseline_abl_operator(img):
    # Simulated 30% global dimming
    return np.clip(img * 0.7, 0, 1)

def icmt_mock_operator(img):
    # REPLACE WITH YOUR ACTUAL ICMT ALGORITHM
    # Simulated perceptual preservation with edge erosion
    return np.clip(img * 0.98 + np.random.normal(0, 0.001, img.shape), 0, 1)

# 3. Simulate processing over datasets
datasets = {
    "Kodak": {"shape": (512, 768, 3), "samples": 24},
    "BSD68": {"shape": (320, 480, 3), "samples": 68},
    "DIV2K (4K HDR)": {"shape": (2160, 3840, 3), "samples": 100}
}

results = {"Dataset": [], "Mean_SSIM": [], "Max_DeltaE": []}

for name, meta in datasets.items():
    ssim_list, delta_e_list = [], []
    for _ in range(3): # Testing on 3 samples per dataset for speed
        img_orig = np.random.rand(*meta["shape"]).astype(np.float32)
        
        # Process
        img_icmt = icmt_mock_operator(img_orig)
        
        # Calculate SSIM
        s_val = ssim(img_orig, img_icmt, data_range=1.0, channel_axis=-1)
        ssim_list.append(s_val)
        
        # Calculate Delta E (CIEDE2000)
        lab_orig = rgb2lab(img_orig)
        lab_icmt = rgb2lab(img_icmt)
        dE = deltaE_ciede2000(lab_orig, lab_icmt)
        delta_e_list.append(np.max(dE)) # Tracking the worst-case shift

    results["Dataset"].append(name)
    results["Mean_SSIM"].append(np.mean(ssim_list))
    results["Max_DeltaE"].append(np.mean(delta_e_list))

# 4. Plot and Save the Bar Chart
fig, ax1 = plt.subplots(figsize=(8, 5))
ax2 = ax1.twinx()

ax1.bar(results["Dataset"], results["Mean_SSIM"], color='blue', alpha=0.6, width=0.4, label='SSIM')
ax2.plot(results["Dataset"], results["Max_DeltaE"], color='red', marker='o', linewidth=2, label='Max Delta E')

ax1.set_ylabel('SSIM (Higher is Better)', color='blue')
ax2.set_ylabel('Max \u0394E (Lower is Better, Limit=1.5)', color='red')
ax2.axhline(1.5, color='red', linestyle='--', label='JND Threshold')

plt.title('ICMT Perceptual Boundedness Across Spatial Resolutions')
fig.legend(loc='upper right', bbox_to_anchor=(0.85, 0.85))
plt.grid(True, alpha=0.3)
plt.savefig(f"{output_dir}/dataset_diversity.pdf", bbox_inches='tight')

# 5. Zip the outputs for download
shutil.make_archive("ICMT_Diversity_Results", 'zip', output_dir)
print("Processing complete. Download 'ICMT_Diversity_Results.zip'.")
