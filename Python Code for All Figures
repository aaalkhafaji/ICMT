import os
import zipfile
import graphviz
from matplotlib.patches import Ellipse

# Create a directory to store the figures
output_dir = "figures"
if not os.path.exists(output_dir):
    os.makedirs(output_dir)

# Set academic plotting style
plt.rcParams.update({
    'font.size': 12,
    'axes.labelsize': 14,
    'axes.titlesize': 16,
    'legend.fontsize': 12,
    'figure.figsize': (8, 6),
    'figure.autolayout': True
})

print("Generating Figure 1: Clifford Basis...")
# ==========================================
# Figure 1: Clifford Basis (3D Multivector Space)
# ==========================================
fig1 = plt.figure()
ax1 = fig1.add_subplot(111, projection='3d')

# Define axes limits
ax1.set_xlim([0, 1])
ax1.set_ylim([0, 1])
ax1.set_zlim([0, 1])

# Plot the 3 bivector planes (APT4, APT5, APT6)
# xy plane (e1e2 - Red/Green)
ax1.plot_surface(np.array([[0, 1], [0, 1]]), np.array([[0, 0], [1, 1]]), np.array([[0, 0], [0, 0]]), color='yellow', alpha=0.1)
# yz plane (e2e3 - Green/Blue)
ax1.plot_surface(np.array([[0, 0], [0, 0]]), np.array([[0, 1], [0, 1]]), np.array([[0, 0], [1, 1]]), color='cyan', alpha=0.15)
# xz plane (e1e3 - Red/Blue)
ax1.plot_surface(np.array([[0, 1], [0, 1]]), np.array([[0, 0], [0, 0]]), np.array([[0, 0], [1, 1]]), color='magenta', alpha=0.1)

# Generate a high-risk UI cluster (Cyan-ish)
