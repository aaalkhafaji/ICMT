print("Generating Figure 6: DPU Architecture Block Diagram...")
# ==========================================
# Figure 6: Hardware Architecture (Graphviz)
# ==========================================
dot = graphviz.Digraph(format='pdf', engine='dot')
dot.attr(rankdir='LR', size='8,5')
dot.attr('node', shape='box', style='filled', fillcolor='lightblue', fontname='Helvetica', fontsize='12')

dot.node('IN', 'Streaming Video\n(Raster Scan)', shape='cylinder', fillcolor='lightgray')
dot.node('BUF', 'Line Buffer Window\n(3x3 Spatial Topology)')
dot.node('LUT', 'LUT-based Rotor Generator $R$\n(Bivector Space)', fillcolor='lightyellow')
dot.node('DEL', 'Delay Buffer\n(Multivector State $\mathbf{U}$)')
dot.node('FWD', 'Spin-Projected Infimal\nConvolution Engine ($\mathcal{C}_{\ominus}$)', fillcolor='lightgreen')
dot.node('INV', 'Inverse Rotor \&\nAdjoint Dilation ($\mathcal{C}_{\oplus}$)', fillcolor='lightgreen')
dot.node('OUT', 'Compensated Display Output', shape='cylinder', fillcolor='lightgray')

dot.edges([('IN', 'BUF'), ('BUF', 'LUT'), ('BUF', 'DEL')])
dot.edge('LUT', 'FWD', label=' Rotor $R$')
dot.edge('DEL', 'FWD', label=' State $\mathbf{U}$')
dot.edge('FWD', 'INV', label=' Eroded State $\mathbf{V}\'$')
dot.edge('LUT', 'INV', label=' Reverse Rotor $\\tilde{R}$')
dot.edge('INV', 'OUT', label=' Output $\mathbf{\hat{U}}$')

dot.render(f'{output_dir}/dpu_architecture', cleanup=True)

print("Packaging figures into a ZIP file...")
# ==========================================
# Zip the Output Files
# ==========================================
zip_filename = "icmt_figures.zip"
with zipfile.ZipFile(zip_filename, 'w') as zipf:
    for root, dirs, files in os.walk(output_dir):
        for file in files:
            if file.endswith(".pdf"):
                zipf.write(os.path.join(root, file), arcname=file)

print(f"Success! All figures generated and compressed into '{zip_filename}'.")
print("You can download the ZIP file using the Colab file browser on the left.")
